{
  "name": "@cinatra-ai/blog-linkedin-publish-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "Publishes a Cinatra blog post to LinkedIn: starts draft generation, polls until ready, pauses for HITL operator review/edit, persists edits, then publishes. Returns linkedinPostUrl on success.",
  "type": "module",
  "files": [
    "cinatra",
    "skills"
  ],
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/linkedin-connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.2"
        },
        "requirement": "required",
        "kind": "connector"
      }
    ],
    "consumes": [
      {
        "primitive": "blog_post_publish_linkedin_start",
        "requirement": "required"
      },
      {
        "primitive": "blog_post_publish_linkedin_update",
        "requirement": "required"
      },
      {
        "primitive": "blog_post_publish_linkedin_publish",
        "requirement": "required"
      },
      {
        "primitive": "blog_post_publish_linkedin_cancel",
        "requirement": "required"
      },
      {
        "primitive": "artifact_authoring_emit",
        "requirement": "required"
      },
      {
        "primitive": "artifact_representation_get",
        "requirement": "required"
      },
      {
        "primitive": "blog_project_get",
        "requirement": "required"
      }
    ],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/blog-linkedin-publish-agent:draft-review",
        "kind": "linkedin-draft-review",
        "priority": 90,
        "midRunHitl": true
      }
    ]
  }
}
